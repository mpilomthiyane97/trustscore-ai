{
  "name": "trustscore-backend",
  "version": "1.0.0",
  "description": "TrustScore backend API for telecom fraud risk simulation",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck"
  },
  "keywords": [
    "trustscore",
    "express",
    "typescript",
    "fraud"
  ],
  "license": "MIT",
  "dependencies": {
    "@types/node": "^22.10.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "network-as-code": "^7.0.0",
    "typescript": "^5.7.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "tsx": "^4.19.2"
  }
}
